# Fuente primaria: Nerd Font oficial. Podés cambiarla localmente si instalás una variante custom.
font-family = FiraCode Nerd Font
font-size = 14

# Paleta Cortex warm/slate
background = #0B0B0A
foreground = #F8F1E7
cursor-color = #F97316
cursor-text = #0B0B0A
selection-background = #7A3500
selection-foreground = #F8F1E7

# Colores ANSI normales
palette = 0=#0B0B0A
palette = 1=#F87171
palette = 2=#10B981
palette = 3=#FBBF24
palette = 4=#60A5FA
palette = 5=#A78BFA
palette = 6=#38BDF8
palette = 7=#F8F1E7

# Colores brillantes
palette = 8=#7D7468
palette = 9=#FCA5A5
palette = 10=#34D399
palette = 11=#FCD34D
palette = 12=#93C5FD
palette = 13=#C4B5FD
palette = 14=#7DD3FC
palette = 15=#FFFFFF

# Transparencia
background-opacity = 0.95
unfocused-split-opacity = 0.85

# Ventana
window-decoration = true
window-padding-balance = true
window-step-resize = false
macos-titlebar-style = tabs
window-padding-x = 4
window-padding-y = 2

# Cursor
cursor-style = block_hollow

# Shaders desactivados en modo trabajo remoto: reducen legibilidad en multiplexers.
# custom-shader = shaders/cursor_smear_soft.glsl

# Integración con shell
shell-integration = zsh

# Option izquierdo como Alt para TUIs; Option derecho conserva tildes/ñ.
macos-option-as-alt = left

# Comportamiento
scrollback-limit = 10000
copy-on-select = clipboard
right-click-action = paste

# Splits
keybind = cmd+shift+d=new_split:down
keybind = cmd+shift+z=toggle_split_zoom
keybind = ctrl+opt+left=resize_split:left,20
keybind = ctrl+opt+right=resize_split:right,20
keybind = ctrl+opt+up=resize_split:up,20
keybind = ctrl+opt+down=resize_split:down,20
keybind = ctrl+opt+equal=equalize_splits
