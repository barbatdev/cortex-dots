# Leader = option + command.

# Focus ventanas
alt + cmd - left  : yabai -m window --focus west || yabai -m window --focus prev || true
alt + cmd - down  : yabai -m window --focus south || yabai -m window --focus next || true
alt + cmd - up    : yabai -m window --focus north || yabai -m window --focus prev || true
alt + cmd - right : yabai -m window --focus east || yabai -m window --focus next || true

# Mover ventanas dentro del layout
alt + cmd + shift - left  : yabai -m window --warp west || yabai -m window --swap west || true
alt + cmd + shift - down  : yabai -m window --warp south || yabai -m window --swap south || true
alt + cmd + shift - up    : yabai -m window --warp north || yabai -m window --swap north || true
alt + cmd + shift - right : yabai -m window --warp east || yabai -m window --swap east || true

# Spaces
alt + cmd - 1 : yabai -m space --focus 1 || true
alt + cmd - 2 : yabai -m space --focus 2 || true
alt + cmd - 3 : yabai -m space --focus 3 || true
alt + cmd - 4 : yabai -m space --focus 4 || true
alt + cmd - 5 : yabai -m space --focus 5 || true
alt + cmd - 6 : yabai -m space --focus 6 || true
alt + cmd - 7 : yabai -m space --focus 7 || true
alt + cmd - 8 : yabai -m space --focus 8 || true
alt + cmd - 9 : yabai -m space --focus 9 || true

# Mover ventana al space y seguirla
alt + cmd + shift - 1 : yabai -m window --space 1 && yabai -m space --focus 1 || true
alt + cmd + shift - 2 : yabai -m window --space 2 && yabai -m space --focus 2 || true
alt + cmd + shift - 3 : yabai -m window --space 3 && yabai -m space --focus 3 || true
alt + cmd + shift - 4 : yabai -m window --space 4 && yabai -m space --focus 4 || true
alt + cmd + shift - 5 : yabai -m window --space 5 && yabai -m space --focus 5 || true
alt + cmd + shift - 6 : yabai -m window --space 6 && yabai -m space --focus 6 || true
alt + cmd + shift - 7 : yabai -m window --space 7 && yabai -m space --focus 7 || true
alt + cmd + shift - 8 : yabai -m window --space 8 && yabai -m space --focus 8 || true
alt + cmd + shift - 9 : yabai -m window --space 9 && yabai -m space --focus 9 || true

# Layout
alt + cmd - f : yabai -m window --toggle float || true
alt + cmd - b : yabai -m space --balance || true
alt + cmd - r : yabai -m config --space window_gap 0; yabai -m space --balance || true; sketchybar --reload
alt + cmd - 0x2C : ~/.config/sketchybar/plugins/shortcuts_help.sh

# Servicios
alt + cmd + shift - r : yabai --restart-service; skhd --reload; sketchybar --reload
