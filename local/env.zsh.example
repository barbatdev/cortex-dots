# local/env.zsh — Configuración personal (NO commitear)
# El instalador crea ~/.config/cortex-dots/local/env.zsh desde este template.

# Directorio raíz de todos tus proyectos
# export WORKSPACE_DIR="$HOME/dev"

# Raíz de estado/runtime de cortex y repos principales.
# export CORTEX_HOME="$HOME/.cortex"
# export CORTEX_ROOT="$CORTEX_HOME/cortex"
# export CORTEX_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/cortex-dots"

# Proyectos personales
# export PERSONAL_PROJECTS_DIR="$WORKSPACE_DIR/personal"

# Proyectos de trabajo
# export WORK_PROJECTS_DIR="$WORKSPACE_DIR/work"

# Herramientas y worktrees locales
# export TOOLS_DIR="$WORKSPACE_DIR/tools"
# export WORKTREES_DIR="$WORKSPACE_DIR/worktrees"

# Directorio de screenshots
# export SCREENSHOTS_DIR="$HOME/Screenshots"

# OpenCode
# export OPENCODE_DEFAULT_FLAGS=""

# Multiplexor preferido para cc/oc y sesiones remotas.
# export CORTEX_MULTIPLEXER="herdr"

# Tokens y API keys para cualquier LLM (nunca en el repo)
# export ANTHROPIC_API_KEY="tu-key-aqui"
# export OPENAI_API_KEY="tu-key-aqui"
# export GEMINI_API_KEY="tu-key-aqui"

# Aliases personales adicionales
# alias my-project="cd $WORK_PROJECTS_DIR/my-project"

# Endpoints de servicios remotos.
# NUNCA commitear el host/IP real; editá tu local/env.zsh con los valores correctos.
# export BRAINS_SERVICE_URL="http://<service-host>:11434"
# export BRAINS_DB_HOST="<service-host>"
# export BRAINS_DB_PORT="5432"
